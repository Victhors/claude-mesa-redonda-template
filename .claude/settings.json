{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "WebSearch"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '---JOURNAL (ultimas entradas)---' && tail -30 JOURNAL.md 2>/dev/null && echo '---CHECKLIST (pendentes)---' && grep -n '\\- \\[ \\]' CHECKLIST.md 2>/dev/null | head -5",
            "statusMessage": "Carregando contexto da Mesa Redonda..."
          }
        ]
      }
    ]
  }
}
